{
  "compilerOptions": {
    // ── Target & Module ────────────────────────────────────────────────────────
    // ES2022 enables native class fields, top-level await, Error.cause, etc.
    // Bundler resolution is correct for Next.js (no need for Node16/NodeNext)
    "target": "ES2022",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "module": "esnext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    // ── Strictness ─────────────────────────────────────────────────────────────
    // Keep full strict mode — catches real bugs at compile time
    "strict": true,
    "noUncheckedIndexedAccess": false, // too noisy for this codebase, opt-in later
    "noImplicitOverride": true, // require explicit `override` keyword
    "exactOptionalPropertyTypes": false, // optional — enable when you're ready
    // ── Interop & Compatibility ───────────────────────────────────────────────
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "allowJs": true,
    "skipLibCheck": true, // trust third-party .d.ts files
    // ── Build Performance ──────────────────────────────────────────────────────
    "isolatedModules": true, // required by Next.js SWC / Turbopack
    "noEmit": true, // Next.js handles emit via SWC — tsc is type-check only
    "incremental": true, // cache type-check results between runs
    "tsBuildInfoFile": ".next/cache/tsconfig.tsbuildinfo", // keep build info inside .next (gitignored)
    // ── Paths ─────────────────────────────────────────────────────────────────
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "./*"
      ]
    },
    // ── Next.js Plugin ────────────────────────────────────────────────────────
    "plugins": [
      {
        "name": "next"
      }
    ]
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    "**/*.mts",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    ".next/cache"
  ]
}
