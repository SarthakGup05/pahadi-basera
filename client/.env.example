# ─────────────────────────────────────────────────────────────────────────────
# Pahadi Basera — Client Environment Variables
# Copy this file to .env.local for local development.
# NEVER commit .env.local to git.
# ─────────────────────────────────────────────────────────────────────────────

# ── Public Variables (safe to expose to browser — prefix with NEXT_PUBLIC_) ──
# Backend API base URL used by the quotation calculator
NEXT_PUBLIC_API_URL=http://localhost:5000

# App URL (used for canonical URLs, OG tags, etc.)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Server-Only Variables (never sent to browser) ─────────────────────────────
# Add secrets here (DB, auth tokens, etc.) — do NOT prefix with NEXT_PUBLIC_
# DATABASE_URL=postgresql://user:password@localhost:5432/pahadi_basera
# AUTH_SECRET=your-super-secret-key-here

# ── Next.js ──────────────────────────────────────────────────────────────────
# Disable telemetry in all environments
NEXT_TELEMETRY_DISABLED=1
